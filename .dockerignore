# Keep the image lean and avoid leaking local state into the build context

# VCS & CI
.git
.github

# Python caches / virtualenvs
__pycache__/
*.py[cod]
.venv
venv/
env/
.pytest_cache/
*.egg-info/

# Local runtime state
servers.json
.env

# Tests, docs and project meta (not needed at runtime)
tests/
docs/
requirements-dev.txt
pytest.ini
assets/
*.md

# Agent / editor scratch
.impeccable/
.superpowers/
.idea/
.vscode/
.DS_Store
